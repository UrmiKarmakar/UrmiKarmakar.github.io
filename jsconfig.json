{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    /* Change checkJs to false to stop the annoying red lines on prop names */
    "checkJs": false, 
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  /* Include all files in src so the editor understands your project structure */
  "include": ["src/**/*"],
  /* Only exclude folders that contain build files or heavy libraries */
  "exclude": ["node_modules", "dist", ".vite"]
}